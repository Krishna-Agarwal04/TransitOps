{
  "info": {
    "_postman_id": "b182e0fa-d2cf-4b71-9c60-705bd94e1d1f",
    "name": "TransitOps Authentication API",
    "description": "Postman collection with examples for user registration, login, and user profile authentication flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"operator@transitops.com\",\n  \"password\": \"securePassword123\",\n  \"name\": \"John Doe\",\n  \"role\": \"OPERATOR\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        },
        "description": "Registers a new user in the TransitOps system. Role can be OPERATOR or ADMIN."
      },
      "response": []
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"operator@transitops.com\",\n  \"password\": \"securePassword123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "description": "Logs in an existing user and returns a JWT token to use in the Authorization header."
      },
      "response": []
    },
    {
      "name": "Get Profile",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{jwt_token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/auth/profile",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "profile"
          ]
        },
        "description": "Retrieves the authenticated user's profile information."
      },
      "response": []
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Checks server health and PostgreSQL database connectivity status."
      },
      "response": []
    }
  ],
  "event": [],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "your_jwt_token_here",
      "type": "string"
    }
  ]
}
